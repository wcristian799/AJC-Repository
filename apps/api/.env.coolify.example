NODE_ENV=production
API_PORT=3000

# Coolify/Postgres: preencha com a URL interna do banco do Coolify.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME

# Gere valores fortes no Coolify.
JWT_SECRET=trocar-por-um-segredo-forte
JWT_REFRESH_SECRET=trocar-por-outro-segredo-forte

# Front aprovado na Vercel + local para smoke/debug.
CORS_ORIGINS=https://ajcmvp.vercel.app,http://localhost:8080

# Integracoes externas ficam stub ate fornecedor/credenciais.
PAYMENT_GATEWAY_MODE=stub
BPE_MODE=stub
WHATSAPP_MODE=stub
BLUETOOTH_PRINT_MODE=stub

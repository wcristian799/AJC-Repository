NODE_ENV=production
API_PORT=3000

# docker-compose.coolify.yml sobe Postgres/PostGIS junto.
POSTGRES_USER=ajc
POSTGRES_PASSWORD=trocar-por-senha-forte
POSTGRES_DB=ajc
DATABASE_URL=postgresql://ajc:trocar-por-senha-forte@postgres:5432/ajc

# Gere valores fortes no Coolify.
AUTH_TOKEN_SECRET=trocar-por-um-segredo-forte-com-32+-chars
AUTH_ACCESS_TTL_SECONDS=900
AUTH_REFRESH_TTL_SECONDS=2592000

# Front aprovado na Vercel + local para smoke/debug.
CORS_ORIGINS=https://ajcmvp.vercel.app,http://localhost:8080

# Integracoes externas ficam stub ate fornecedor/credenciais.
PAYMENT_GATEWAY_MODE=stub
BPE_MODE=stub
WHATSAPP_MODE=stub
BLUETOOTH_PRINT_MODE=stub

# Object storage MVP no VPS: MinIO S3-compatible.
OBJECT_STORAGE_DRIVER=minio
OBJECT_STORAGE_ENDPOINT=http://minio:9000
OBJECT_STORAGE_PUBLIC_URL=https://storage-ajc.byteintelligence.com.br
OBJECT_STORAGE_ACCESS_KEY=trocar-por-access-key
OBJECT_STORAGE_SECRET_KEY=trocar-por-secret-key-forte
OBJECT_STORAGE_REGION=us-east-1
MINIO_ROOT_USER=trocar-admin-minio
MINIO_ROOT_PASSWORD=trocar-admin-password-forte

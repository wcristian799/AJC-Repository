# Variáveis de ambiente — copie para .env e ajuste. NUNCA commite o .env real.

# ── Postgres (docker-compose) ──────────────────────────────────────
POSTGRES_USER=ajc
POSTGRES_PASSWORD=ajc_dev
POSTGRES_DB=ajc

# ── Back (NestJS) ──────────────────────────────────────────────────
# App desacoplado por DATABASE_URL (trocar a string muda o alvo do banco —
# facilita migração futura para Cloud SQL/RDS, ver ADR 01 §3).
DATABASE_URL=postgresql://ajc:ajc_dev@localhost:5432/ajc
API_PORT=3000

# ── Seed ───────────────────────────────────────────────────────────
# Senha do admin de desenvolvimento (o seed grava apenas o HASH, nunca o texto).
SEED_ADMIN_EMAIL=admin@ajc.local
SEED_ADMIN_PASSWORD=troca_isto_em_dev
